{
  "name": "exposure-logger",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start --dev-client",
    "android": "expo start --dev-client --android",
    "android:native": "expo run:android",
    "ios": "expo start --dev-client --ios",
    "ios:native": "expo run:ios",
    "build:android": "eas build --platform android --profile production",
    "build:ios": "eas build --platform ios --profile production",
    "submit:android": "eas submit --platform android --profile production",
    "submit:ios": "eas submit --platform ios --profile production",
    "web": "expo start --web",
    "lint": "eslint .",
    "format": "prettier --check .",
    "test": "jest"
  },
  "dependencies": {
    "drizzle-orm": "^0.45.1",
    "expo": "~55.0.7",
    "expo-asset": "^55.0.10",
    "expo-dev-client": "^55.0.18",
    "expo-file-system": "~55.0.11",
    "expo-location": "^55.1.4",
    "expo-router": "^55.0.7",
    "expo-sharing": "~55.0.14",
    "expo-speech-recognition": "^3.1.2",
    "expo-sqlite": "^55.0.11",
    "expo-status-bar": "~55.0.4",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-native": "0.83.2",
    "react-native-gesture-handler": "^2.30.0",
    "react-native-reanimated": "^4.2.1",
    "react-native-safe-area-context": "~5.6.2",
    "react-native-screens": "~4.23.0",
    "react-native-svg": "^15.15.4",
    "react-native-web": "^0.21.0",
    "react-test-renderer": "19.2.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.2",
    "babel-preset-expo": "^55.0.12",
    "eslint": "^9.39.4",
    "eslint-config-expo": "^55.0.0",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.11",
    "prettier": "^3.8.1",
    "typescript": "~5.9.2"
  },
  "private": true
}
